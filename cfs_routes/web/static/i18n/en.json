  "help.help": "<h6 class=\"text-uppercase text-secondary fw-bold mb-3\" style=\"font-size:0.7rem;letter-spacing:.08em\">How to Use</h6>\n\n<ol class=\"small ps-3 mb-4\">\n  <li class=\"mb-2\">Select a departure airport from the dropdown and click <strong>Add</strong> \u2014 repeat for each departure airport you need.</li>\n  <li class=\"mb-2\">In a row\u2019s destination field, type an ICAO code (e.g.\u00a0<span class=\"font-mono\">CYYC</span>) or a cardinal direction (e.g.\u00a0<span class=\"font-mono\">NE</span>), then press <kbd>Enter</kbd> or click the search button.</li>\n  <li class=\"mb-0\">The modal shows all mandatory IFR routes for that pair, grouped by altitude (HIGH / LOW). When no specific route exists for a destination, all cardinal direction departure routes from that airport are shown instead.</li>\n</ol>\n\n<h6 class=\"text-uppercase text-secondary fw-bold mb-3\" style=\"font-size:0.7rem;letter-spacing:.08em\">Keyboard Shortcuts</h6>\n\n<table class=\"table table-sm table-borderless font-mono small mb-4\">\n  <tbody>\n    <tr>\n      <td class=\"ps-0 text-nowrap\"><kbd>Ctrl</kbd> + <kbd>K</kbd></td>\n      <td>Open the airport search dropdown</td>\n    </tr>\n    <tr>\n      <td class=\"ps-0 text-nowrap\"><kbd>\u2191</kbd> / <kbd>\u2193</kbd></td>\n      <td>Move between destination fields</td>\n    </tr>\n  </tbody>\n</table>\n\n<h6 class=\"text-uppercase text-secondary fw-bold mb-3\" style=\"font-size:0.7rem;letter-spacing:.08em\">Leader Key</h6>\n\n<p class=\"small mb-2\">\n  Press <kbd>Esc</kbd> to activate the leader key, then within 1.5\u00a0s press a digit to focus that row\u2019s destination field.\n</p>\n\n<table class=\"table table-sm table-borderless font-mono small mb-0\">\n  <tbody>\n    <tr>\n      <td class=\"ps-0 text-nowrap\"><kbd>Esc</kbd> \u2192 <kbd>1</kbd>\u2013<kbd>0</kbd></td>\n      <td>Focus destination field for row 1\u201310</td>\n    </tr>\n  </tbody>\n</table>"
}
